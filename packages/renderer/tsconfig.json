{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "declarationMap": true,
    "noEmit": false,
    "sourceMap": true,
    "verbatimModuleSyntax": false,
    "strictPropertyInitialization": false,
    "isolatedModules": false,
    "strictFunctionTypes": false,
    "useUnknownInCatchVariables": false,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": ["dist"]
}
